{
  "name": "payblocks",
  "version": "3.0.1",
  "description": "A Website template for PayloadCMS, featurig shadcn/ui and shadcnblocks.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm payload generate:types && cross-env NODE_OPTIONS=--no-deprecation next build",
    "analyze": "cross-env ANALYZE=true NODE_OPTIONS=--no-deprecation pnpm build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack",
    "dev:debug": "cross-env NODE_OPTIONS='--no-deprecation --inspect' next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "tsc": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "backup": "source .env && mongoexport -c pages --uri=$MONGODB_URI --out backup/pages.json --jsonArray",
    "backup:apply": "source .env && mongoimport -c pages --uri=$MONGODB_URI --file backup/pages.json --jsonArray --mode upsert",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "orisa:sync-assets": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/orisa/sync-assets.ts",
    "seed:orisa-globals": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-orisa-globals.ts",
    "seed:orisa-creative-agency": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-orisa-creative-agency.ts",
    "seed:orisa-marketing-agency": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-orisa-marketing-agency.ts",
    "seed:orisa-about-01": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-orisa-about-01.ts",
    "seed:orisa-contact-01": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-orisa-contact-01.ts",
    "seed:orisa-all-bundles": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-orisa-all-bundles.ts",
    "seed:storeframe-bundles": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/seed-storeframe-bundles.ts",
    "purge:legacy-demos": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/purge-legacy-demos.ts",
    "postinstall": "node scripts/patch-payload-ui-client-bundle.mjs"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.82.1",
    "@payloadcms/db-mongodb": "3.82.1",
    "@payloadcms/db-postgres": "3.82.1",
    "@payloadcms/email-nodemailer": "3.82.1",
    "@payloadcms/email-resend": "3.82.1",
    "@payloadcms/live-preview-react": "3.82.1",
    "@payloadcms/next": "3.82.1",
    "@payloadcms/plugin-form-builder": "3.82.1",
    "@payloadcms/plugin-nested-docs": "3.82.1",
    "@payloadcms/plugin-redirects": "3.82.1",
    "@payloadcms/plugin-search": "3.82.1",
    "@payloadcms/plugin-seo": "3.82.1",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/storage-vercel-blob": "3.82.1",
    "@payloadcms/translations": "3.82.1",
    "@payloadcms/ui": "3.82.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@trieb.work/payload-plugin-backup-mongodb": "^0.1.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^0.27.3",
    "bson": "^6.10.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^2.0.1",
    "cross-env": "^10.1.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-fade": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.0",
    "geist": "^1.7.0",
    "graphql": "^16.12.0",
    "gsap": "^3.15.0",
    "jsonwebtoken": "9.0.3",
    "lenis": "^1.3.23",
    "lucide-react": "^1.8.0",
    "motion": "^12.34.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "payload": "3.82.1",
    "payload-oauth2": "1.0.21",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "react-icons": "^5.5.0",
    "react-phone-number-input": "^3.4.14",
    "react-responsive-masonry": "^2.7.1",
    "react-turnstile": "^1.1.5",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
