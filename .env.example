# =============================================================================
# Payblocks — local development (.env.example)
# Copy to .env: cp .env.example .env
# Start MongoDB: docker compose up -d mongo
# Start app:     pnpm install && pnpm dev
# =============================================================================

# Database (must match docker-compose mongo on localhost:27017)
MONGODB_URI=mongodb://127.0.0.1:27017/payblocks

# JWT / session encryption — change in production
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public app URL (CORS, CSRF, preview links)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Draft / live preview
NEXT_PRIVATE_DRAFT_SECRET=change-me-draft-secret

# On-demand revalidation
REVALIDATION_KEY=change-me-revalidation-key
NEXT_PRIVATE_REVALIDATION_KEY=change-me-revalidation-key

# Admin CLI — POST http://localhost:3000/next/admin/cli (localhost only)
ADMIN_CLI_SECRET=change-me-admin-cli-secret

# Vercel Blob — media + backups (optional locally; files fall back to public/)
# BLOB_READ_WRITE_TOKEN=

# Email via Resend (optional for local dev; forms may need this in production)
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@example.com

# Cloudflare Turnstile — form bot protection (optional)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# NEXT_PRIVATE_TURNSTILE_SECRET_KEY=

# Google OAuth admin login (optional)
# GOOGLE_LOGIN_CLIENT_ID=
# GOOGLE_LOGIN_CLIENT_SECRET=
# ALLOWED_EMAIL_DOMAINS=

# Backup cron (production / Vercel)
CRON_SECRET=local-cron-secret
BACKUPS_TO_KEEP=4

# Orisa theme asset sync (local dev only — pnpm orisa:sync-assets)
# ORISA_THEME_PATH=/path/to/Orisa_v4.1.0_Unzip-First
